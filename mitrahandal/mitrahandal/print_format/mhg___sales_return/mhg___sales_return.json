 "html": "<!DOCTYPE html>\n<html lang=\"id\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        @page {\n            size: A4;\n            margin: 0;\n        }\n        body {\n            font-family: Arial, sans-serif;\n            font-size: 9pt;\n            margin: 0;\n            padding: 10px;\n            color: #003366; /* Blue tone similar to the image */\n        }\n        \n        .container {\n            width: 100%;\n            max-width: 210mm;\n            margin: 0 auto;\n            background-color: #fff;\n        }\n\n        /* --- HEADER SECTION --- */\n        .header-wrapper {\n            width: 100%;\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 5px;\n            border-bottom: 2px solid #003366;\n            padding-bottom: 5px;\n        }\n\n        .header-left {\n            width: 40%;\n            vertical-align: top;\n        }\n        .header-left .logo-text {\n            font-weight: bold;\n            font-size: 11pt;\n            margin-bottom: 2px;\n        }\n        .header-left .address {\n            font-size: 7.5pt;\n            line-height: 1.2;\n        }\n\n        .header-center {\n            width: 20%;\n            text-align: center;\n            vertical-align: top;\n            padding-top: 10px;\n        }\n        .header-center .title {\n            font-weight: bold;\n            font-size: 12pt;\n            margin-bottom: 5px;\n        }\n\n        .header-right {\n            width: 40%;\n            vertical-align: top;\n        }\n        .info-table {\n            width: 100%;\n            font-size: 8pt;\n        }\n        .info-table td {\n            padding: 1px 0;\n        }\n        .info-label {\n            width: 80px;\n        }\n\n        /* --- RECIPIENT SECTION --- */\n        .recipient-section {\n            margin-bottom: 10px;\n        }\n        .recipient-label {\n            font-weight: bold;\n            font-size: 8pt;\n            margin-bottom: 2px;\n        }\n        .recipient-name {\n            font-weight: bold;\n            font-size: 9pt;\n        }\n        .recipient-address {\n            font-size: 8pt;\n            line-height: 1.2;\n            width: 60%;\n        }\n\n        /* --- PKP CHECKBOX --- */\n        .pkp-box {\n            float: right;\n            margin-bottom: 5px;\n            font-size: 8pt;\n            font-weight: bold;\n        }\n        .pkp-box span {\n            margin-right: 10px;\n        }\n\n        /* --- ITEMS TABLE --- */\n        .items-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 8pt;\n            margin-bottom: 20px;\n        }\n        .items-table th {\n            border: 1px solid #003366;\n            background-color: #eef2f5;\n            padding: 4px;\n            text-align: center;\n            font-weight: bold;\n        }\n        .items-table td {\n            border: 1px solid #003366;\n            padding: 4px;\n            vertical-align: top;\n        }\n        \n        /* Specific column widths to match image */\n        .col-no { width: 5%; text-align: center; }\n        .col-code { width: 10%; }\n        .col-name { width: 35%; }\n        .col-qty { width: 10%; text-align: center; }\n        .col-price { width: 10%; text-align: right; }\n        .col-total { width: 12%; text-align: right; }\n        .col-sat { width: 5%; text-align: center; }\n        .col-desc { width: 13%; }\n\n        /* --- FOOTER --- */\n        .footer-wrapper {\n            width: 100%;\n            display: flex;\n            justify-content: space-between;\n            margin-top: 10px;\n        }\n\n        .signatures {\n            width: 60%;\n        }\n        .signature-table {\n            width: 100%;\n            border-collapse: collapse;\n        }\n        .signature-table td {\n            text-align: center;\n            vertical-align: top;\n            padding: 5px;\n        }\n        .sig-label {\n            font-weight: bold;\n            font-size: 9pt;\n            margin-bottom: 40px;\n            display: block;\n        }\n        .sig-line {\n            border-bottom: 1px solid #003366;\n            width: 80%;\n            margin: 0 auto;\n        }\n\n        .totals {\n            width: 35%;\n        }\n        .totals-table {\n            width: 100%;\n            font-size: 8pt;\n        }\n        .totals-table td {\n            padding: 2px 5px;\n        }\n        .total-label {\n            text-align: right;\n        }\n        .total-value {\n            text-align: right;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <!-- Header -->\n        <div class=\"header-wrapper\">\n            <div class=\"header-left\">\n                <div class=\"logo-text\">PT. MITRA HANDAL GEMILANG</div>\n                <div class=\"address\">\n                    JL. KEMANG RAYA NO.99 RT.003 RW.010<br>\n                    KEMANG, KEMANG KAB. BOGOR - JAWA BARAT<br>\n                    NPWP : 000000\n                </div>\n            </div>\n            <div class=\"header-center\">\n                <div class=\"title\">NOTA RETUR</div>\n                <div>No. : {{ doc.name or '2603RJ015' }}</div>\n            </div>\n            <div class=\"header-right\">\n                <table class=\"info-table\">\n                    <tr>\n                        <td class=\"info-label\">Tanggal</td>\n                        <td>: {{ doc.posting_date or '08/04/2026' }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"info-label\">No. NR</td>\n                        <td>: {{ doc.name or '25120288' }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"info-label\">No. Lang.</td>\n                        <td>: MKJBTSISK001</td>\n                    </tr>\n                    <tr>\n                        <td class=\"info-label\">Salesman</td>\n                        <td>: MK07 RIAN MUNANDAR</td>\n                    </tr>\n                </table>\n            </div>\n        </div>\n\n        <!-- Recipient -->\n        <div class=\"recipient-section\">\n            <div class=\"recipient-label\">Kepada Yth,</div>\n            <div class=\"recipient-name\">{{ doc.customer_name or \"TOKO ISKANDAR ( CEMPAKA PUTIH BARAT )\" }}</div>\n            <div class=\"recipient-address\">\n                {{ doc.address_display or \"JL. A RANO 7 B KP. JATI RT.003 RW.003 KEL JATI KEC.PULOGADUNG JAKARTA TIMUR\" }}\n            </div>\n            \n            <div class=\"pkp-box\">\n                <span>PKP: [ ]</span>\n                <span>Non PKP: [X]</span>\n            </div>\n        </div>\n\n        <!-- Items Table -->\n        <table class=\"items-table\">\n            <thead>\n                <tr>\n                    <th class=\"col-no\">No</th>\n                    <th class=\"col-code\">KODE BARANG</th>\n                    <th class=\"col-name\">NAMA BARANG</th>\n                    <th class=\"col-qty\">KUANTITAS</th>\n                    <th class=\"col-price\">HARGA UNIT</th>\n                    <th class=\"col-total\">HARGA TOTAL</th>\n                    <th class=\"col-sat\">SAT</th>\n                    <th class=\"col-desc\">KETERANGAN</th>\n                </tr>\n            </thead>\n            <tbody>\n                {% set ns = namespace(total_qty=0, total_amount=0) %}\n                {% for item in doc.items %}\n                    {% set ns.total_qty = ns.total_qty + (item.qty or 0) %}\n                    {% set ns.total_amount = ns.total_amount + (item.amount or 0) %}\n                <tr>\n                    <td class=\"col-no\">{{ loop.index }}</td>\n                    <td>{{ item.item_code or \"M.002\" }}</td>\n                    <td>{{ item.item_name or \"Badan M 32x2\" }}</td>\n                    <td class=\"col-qty\">{{ item.qty or \"\" }}</td>\n                    <td class=\"col-price\">\n                        {% if item.rate %}\n                            {{ \"{:,.2f}\".format(item.rate).replace(',', '.') }}\n                        {% endif %}\n                    </td>\n                    <td class=\"col-total\">\n                        {% if item.amount %}\n                            {{ \"{:,.2f}\".format(item.amount).replace(',', '.') }}\n                        {% endif %}\n                    </td>\n                    <td class=\"col-sat\">{{ item.uom or \"\" }}</td>\n                    <td>{{ item.remarks or \"\" }}</td>\n                </tr>\n                {% endfor %}\n            </tbody>\n        </table>\n\n        <!-- Footer -->\n        <div class=\"footer-wrapper\">\n            <div class=\"signatures\">\n                <table class=\"signature-table\">\n                    <tr>\n                        <td style=\"width: 33%;\">\n                            <span class=\"sig-label\">Hormat kami,</span>\n                            <div class=\"sig-line\"></div>\n                        </td>\n                        <td style=\"width: 33%;\">\n                            <span class=\"sig-label\">Mengetahui,</span>\n                            <div class=\"sig-line\"></div>\n                        </td>\n                        <td style=\"width: 33%;\">\n                            <span class=\"sig-label\">Penerima,</span>\n                            <div class=\"sig-line\"></div>\n                        </td>\n                    </tr>\n                </table>\n            </div>\n\n            <div class=\"totals\">\n                <table class=\"totals-table\">\n                    <tr>\n                        <td class=\"total-label\">Jumlah Harga Jual :</td>\n                        <td class=\"total-value\">\n                            {% if doc.grand_total %}\n                                {{ \"{:,.2f}\".format(doc.grand_total).replace(',', '.') }}\n                            {% else %}\n                                139,206,00\n                            {% endif %}\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"total-label\">Diskon/Potongan :</td>\n                        <td class=\"total-value\">\n                            {% if doc.discount_amount %}\n                                {{ \"{:,.2f}\".format(doc.discount_amount).replace(',', '.') }}\n                            {% else %}\n                                1,297,00\n                            {% endif %}\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"total-label\">Dasar Pengenaan Pajak :</td>\n                        <td class=\"total-value\">\n                            {% if doc.base_net_total %}\n                                {{ \"{:,.2f}\".format(doc.base_net_total).replace(',', '.') }}\n                            {% else %}\n                                137,909,00\n                            {% endif %}\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"total-label\">PPN (11%) :</td>\n                        <td class=\"total-value\">\n                            {% if doc.total_taxes_and_charges %}\n                                {{ \"{:,.2f}\".format(doc.total_taxes_and_charges).replace(',', '.') }}\n                            {% else %}\n                                0,00\n                            {% endif %}\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"total-label\" style=\"font-weight: bold;\">TOTAL :</td>\n                        <td class=\"total-value\" style=\"font-weight: bold;\">\n                            {% if doc.grand_total %}\n                                {{ \"{:,.2f}\".format(doc.grand_total).replace(',', '.') }}\n                            {% else %}\n                                137,909,00\n                            {% endif %}\n                        </td>\n                    </tr>\n                </table>\n            </div>\n        </div>\n    </div>\n</body>\n</html>",
