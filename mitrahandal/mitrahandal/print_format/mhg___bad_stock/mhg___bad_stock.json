    "html": "<div style=\"padding: 10px; font-size: 10pt; font-family: Arial, sans-serif;\">\n\n<div style=\"font-size: 12pt; font-weight: bold; margin-bottom: 5px;\">BERITA ACARA SERAH TERIMA BARANG RUSAK (BAD STOCK)</div>\n<div style=\"font-size: 10pt; margin-bottom: 3px;\">{{ filters.company }}</div>\n<div style=\"font-size: 10pt; margin-bottom: 3px;\">PERIODE {{ filters.start_date.split(\"-\")[2] }}/{{ filters.start_date.split(\"-\")[1] }}/{{ filters.start_date.split(\"-\")[0] }} - {{ filters.end_date.split(\"-\")[2] }}/{{ filters.end_date.split(\"-\")[1] }}/{{ filters.end_date.split(\"-\")[0] }}</div>\n<div style=\"font-size: 10pt; margin-bottom: 15px;\">AREA {{ filters.warehouse }}</div>\n\n<table style=\"width: 100%; border-collapse: collapse;\">\n  <thead>\n    <tr>\n      <th style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt; background-color: #f0f0f0; font-weight: bold; width: 5%;\">NO</th>\n      <th style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt; background-color: #f0f0f0; font-weight: bold; width: 15%;\">PART</th>\n      <th style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt; background-color: #f0f0f0; font-weight: bold; width: 40%;\">PRODUK</th>\n      <th style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt; background-color: #f0f0f0; font-weight: bold; width: 10%;\">ISI</th>\n      <th style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt; background-color: #f0f0f0; font-weight: bold; width: 15%;\">IN KARTON</th>\n      <th style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt; background-color: #f0f0f0; font-weight: bold; width: 15%;\">IN PCS</th>\n    </tr>\n  </thead>\n  <tbody>\n    {% set total_in_karton = 0 %}\n    {% set total_in_pcs = 0 %}\n    {% set row_num = 0 %}\n    {% for row in data %}\n      {% set row_num = row_num + 1 %}\n      {% set total_in_karton = total_in_karton + row.in_karton %}\n      {% set total_in_pcs = total_in_pcs + row.in_pcs %}\n      <tr>\n        <td style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt;\">{{ row_num }}</td>\n        <td style=\"border: 1px solid #000; padding: 4px 8px; font-size: 9pt;\">{{ row.part }}</td>\n        <td style=\"border: 1px solid #000; padding: 4px 8px; font-size: 9pt;\">{{ row.produk }}</td>\n        <td style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt;\">{{ row.isi }}</td>\n        <td style=\"border: 1px solid #000; padding: 4px 8px; text-align: right; font-size: 9pt;\">{{ \"{:,.3f}\".format(row.in_karton) }}</td>\n        <td style=\"border: 1px solid #000; padding: 4px 8px; text-align: right; font-size: 9pt;\">{{ \"{:,.0f}\".format(row.in_pcs) }}</td>\n      </tr>\n    {% endfor %}\n    <tr>\n      <td colspan=\"4\" style=\"border: 1px solid #000; padding: 4px 8px; text-align: center; font-size: 9pt; font-weight: bold;\">TOTAL</td>\n      <td style=\"border: 1px solid #000; padding: 4px 8px; text-align: right; font-size: 9pt; font-weight: bold;\">{{ \"{:,.2f}\".format(total_in_karton) }}</td>\n      <td style=\"border: 1px solid #000; padding: 4px 8px; text-align: right; font-size: 9pt; font-weight: bold;\">{{ \"{:,.0f}\".format(total_in_pcs) }}</td>\n    </tr>\n  </tbody>\n</table>\n\n<div style=\"margin-top: 40px;\">\n  <table style=\"width: 100%;\">\n    <tr>\n      <td style=\"width: 25%; text-align: center; vertical-align: top; padding: 10px; border: none;\">\n        <div style=\"font-size: 9pt;\">Dibuat Oleh,</div>\n        <div style=\"font-weight: bold; text-decoration: underline; margin-top: 60px; font-size: 9pt;\">Suprationo</div>\n        <div style=\"font-size: 9pt;\">Kepala Gudang</div>\n      </td>\n      <td style=\"width: 25%; text-align: center; vertical-align: top; padding: 10px; border: none;\">\n        <div style=\"font-size: 9pt;\">Mengetahui,</div>\n        <div style=\"font-weight: bold; text-decoration: underline; margin-top: 60px; font-size: 9pt;\">Mitchella Purnamasari</div>\n        <div style=\"font-size: 9pt;\">General Manager</div>\n      </td>\n      <td style=\"width: 25%; text-align: center; vertical-align: top; padding: 10px; border: none;\">\n        <div style=\"font-size: 9pt;\">Menyetujui,</div>\n        <div style=\"font-weight: bold; text-decoration: underline; margin-top: 60px; font-size: 9pt;\">Christopher Goldwin</div>\n        <div style=\"font-size: 9pt;\">Direktur</div>\n      </td>\n      <td style=\"width: 25%; text-align: center; vertical-align: top; padding: 10px; border: none;\">\n        <div style=\"font-size: 9pt;\">Diterima Oleh,</div>\n        <div style=\"font-weight: bold; text-decoration: underline; margin-top: 60px; font-size: 9pt;\">____________________</div>\n        <div style=\"font-size: 9pt;\">{{ filters.company }}</div>\n      </td>\n    </tr>\n  </table>\n</div>\n\n</div>\n",
